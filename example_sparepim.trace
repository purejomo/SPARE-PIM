# SPARE-PIM per-BPU VOC metadata trace.
# Format: VOC voc0,voc1,... [addr] [mac_cmds] [acc_cmds]
#
# Each line is one pseudochannel-local sparse PV step. The 16 entries are
# BPU-level VOC values: 4 BGMUs x 4 banks/BPUs per bankgroup. Each VOC is
# bounded by the FSU width, so max_voc_per_bpu=16 for this configuration.
VOC 9,12,7,10,8,11,13,6,14,9,10,12,7,8,11,15 0x0
VOC 4,6,5,7,3,8,6,5,9,4,7,6,5,3,8,4 0x40
VOC 16,15,14,13,12,16,15,14,13,12,11,10,16,15,14,13 0x80
VOC 2,1,3,4,0,2,1,3,5,4,2,1,3,0,2,4 0xc0
